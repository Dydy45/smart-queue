# ========================================
# DATABASE CONFIGURATION
# ========================================

# PostgreSQL Database URL (Production & Development)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://postgres:password@localhost:5432/smartqueue?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/smartqueue?schema=public"

# SQLite Database URL (Development Only - Legacy)
# DATABASE_URL="file:./dev.db"

# ========================================
# CLERK AUTHENTICATION
# ========================================

# Get these from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key_here"
CLERK_SECRET_KEY="your_clerk_secret_key_here"

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ========================================
# WEBSOCKET CONFIGURATION
# ========================================

# WebSocket Server URL (Client-side)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# WebSocket Server Port (Server-side)
SOCKET_PORT=3001

# ========================================
# RATE LIMITING (Production)
# ========================================

# Upstash Redis URL (for distributed rate limiting)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token_here"

# ========================================
# DEPLOYMENT
# ========================================

# Production URL
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Node Environment
NODE_ENV="development"
